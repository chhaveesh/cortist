# ---------------------------------------------------------------------------
# Cortist — Phase 1 environment
# Copy to .env: `cp .env.example .env`. The defaults below work as-is with
# `docker compose up`; no real Telegram credentials are needed to run or test.
# ---------------------------------------------------------------------------

# Runtime mode: development | test | production
NODE_ENV=development

# Port the webhook gateway listens on (inside the container and on the host).
PORT=3000

# Minimum log level: error | warn | log | debug | verbose
LOG_LEVEL=log

# --- Postgres --------------------------------------------------------------
# Credentials used to initialise the Postgres container.
POSTGRES_USER=cortist
POSTGRES_PASSWORD=cortist
POSTGRES_DB=cortist

# Connection string used by the app. Host is the compose service name; change
# `postgres` to `localhost` when running the app outside Docker.
DATABASE_URL=postgresql://cortist:cortist@postgres:5432/cortist?schema=public

# Host port the Postgres container is published on. Only affects access from
# your machine (e.g. psql) — set this if you already run Postgres on 5432.
POSTGRES_HOST_PORT=5432

# --- Redis (queue + dedupe keys) -------------------------------------------
# Host is the compose service name; use `localhost` when running outside Docker.
REDIS_HOST=redis
REDIS_PORT=6379
# Leave empty for the local unauthenticated Redis container.
REDIS_PASSWORD=
# Logical Redis database index (0-15).
REDIS_DB=0

# Host port the Redis container is published on. As above, only affects access
# from your machine (e.g. redis-cli).
REDIS_HOST_PORT=6379

# --- Telegram --------------------------------------------------------------
# Bot token from @BotFather. Only needed to SEND messages (Phase 2+); a
# placeholder is fine for Phase 1 ingestion and for the whole test suite.
TELEGRAM_BOT_TOKEN=placeholder-bot-token

# Shared secret proving a request really came from Telegram. This value MUST
# match the `secret_token` you pass to setWebhook when registering the webhook —
# Telegram echoes it back in the X-Telegram-Bot-Api-Secret-Token header on every
# delivery, and the gateway rejects anything that does not match with a 401.
# Setting it here without registering it with Telegram means all deliveries 401.
# Generate a real one with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=local-dev-webhook-secret

# --- Tuning ----------------------------------------------------------------
# How long a (chat_id, message_id) pair is remembered for dedupe, in seconds.
# Must comfortably exceed Telegram's retry window. Default: 24 hours.
DEDUPE_TTL_SECONDS=86400

# Jobs a single worker process handles concurrently.
WORKER_CONCURRENCY=5
