// Cortist Phase 1 data model.
//
// Deliberately minimal: the only durable state this phase owns is the mapping
// from a Telegram identity to an internal tenant, plus a marker table the stub
// worker writes to so the end-to-end pipe is observable from tests.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

/// One row per onboarded Telegram user. `id` is the internal tenant identifier
/// that every downstream agent (Phase 2+) should key off — never the Telegram id.
model User {
  id             String   @id @default(uuid()) @db.Uuid
  telegramUserId BigInt   @unique @map("telegram_user_id")
  telegramChatId BigInt   @map("telegram_chat_id")
  /// IANA zone, cached from the user's primary calendar.
  ///
  /// Stored rather than fetched per message for two reasons: the router needs
  /// it to resolve "tomorrow at 3pm" during extraction and has no calendar
  /// access, and fetching it previously cost an extra Google API call on every
  /// single calendar message.
  timeZone       String?  @map("time_zone")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  oauthTokens         OAuthToken[]
  pendingAction       PendingAction?
  pendingClarification PendingClarification?
  documents      Document[]
  documentChunks DocumentChunk[]

  @@map("users")
}

/// A document the user asked Cortist to remember.
model Document {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  /// 'pdf' | 'text' | 'url' — see DocumentSourceType.
  sourceType String   @map("source_type")
  /// Filename, URL, or a short label for pasted text.
  sourceName String   @map("source_name")
  /// LLM-generated one-paragraph summary of the whole document.
  summary    String
  tags       String[]
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks DocumentChunk[]

  @@index([userId], map: "documents_user_id_idx")
  @@map("documents")
}

/// One embedded slice of a document.
///
/// `embedding` is a pgvector column and is NOT represented here — Prisma has no
/// native vector type, so it is added by migration and queried through raw SQL
/// in VectorStoreService. Everything else stays in the Prisma model so ordinary
/// reads and cascades keep working.
model DocumentChunk {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  /// Denormalized from documents so a vector search can filter by tenant
  /// without a join — the join would defeat the index and, more importantly,
  /// makes the isolation boundary easy to omit by accident.
  userId     String   @map("user_id") @db.Uuid
  content    String
  chunkIndex Int      @map("chunk_index")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex], map: "document_chunks_document_id_chunk_index_key")
  @@index([userId], map: "document_chunks_user_id_idx")
  @@map("document_chunks")
}

/// One row per user per external provider. Both tokens are encrypted at rest
/// with AES-256-GCM; nothing in this table is readable without TOKEN_ENCRYPTION_KEY.
model OAuthToken {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  provider              String
  accessTokenEncrypted  String   @map("access_token_encrypted")
  /// Nullable: Google only returns a refresh token on first consent, so a
  /// re-consent that omits it must not wipe the one we already hold.
  refreshTokenEncrypted String?  @map("refresh_token_encrypted")
  expiresAt             DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider], map: "oauth_tokens_user_id_provider_key")
  @@map("oauth_tokens")
}

/// A destructive action awaiting the user's explicit "yes".
///
/// At most one per tenant (unique on user_id): a new request supersedes any
/// unanswered one, which matches how the conversation actually reads — the
/// user's "yes" always refers to the most recent question asked.
model PendingAction {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  /// 'delete_event' | 'reschedule_event' — see PendingActionType.
  actionType String  @map("action_type")
  /// The resolved, ready-to-execute action. Validated on read, never trusted.
  payload   Json
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt], map: "pending_actions_expires_at_idx")
  @@map("pending_actions")
}

/// Written by the stub worker to prove gateway -> queue -> worker delivery.
/// Phase 2 will replace this with real agent output; the unique constraint on
/// (chat_id, message_id) also acts as a durable backstop against double
/// processing if the Redis dedupe key has already expired.
model ProcessedMessage {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  chatId      BigInt   @map("chat_id")
  messageId   Int      @map("message_id")
  text        String
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  @@unique([chatId, messageId], map: "processed_messages_chat_id_message_id_key")
  @@map("processed_messages")
}

/// A routing question awaiting the user's answer.
///
/// Separate from PendingAction: that one guards a destructive calendar action,
/// this one resolves which agent a message belongs to. Conflating them would
/// mean a "yes" could mean either "delete the event" or "the calendar one",
/// which is exactly the ambiguity this table exists to remove.
model PendingClarification {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  /// The message we could not route, replayed verbatim once the user answers.
  originalText String   @map("original_text")
  /// The two routes the classifier was torn between.
  routeA       String   @map("route_a")
  routeB       String   @map("route_b")
  /// How many times we have already asked. Capped to stop a loop.
  attempts     Int      @default(1)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt], map: "pending_clarifications_expires_at_idx")
  @@map("pending_clarifications")
}
