# Environment for the automated test suite. Points at the isolated containers
# defined in docker-compose.test.yml. Committed on purpose — these are
# throwaway credentials for ephemeral containers, and the suite must run with
# zero manual setup.

NODE_ENV=test
PORT=3001
LOG_LEVEL=warn

DATABASE_URL=postgresql://cortist_test:cortist_test@localhost:55432/cortist_test?schema=public

REDIS_HOST=localhost
REDIS_PORT=56379
REDIS_PASSWORD=
REDIS_DB=0

TELEGRAM_BOT_TOKEN=test-bot-token
TELEGRAM_WEBHOOK_SECRET=test-webhook-secret

DEDUPE_TTL_SECONDS=60
WORKER_CONCURRENCY=2
