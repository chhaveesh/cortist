# Environment for the automated test suite. Points at the isolated containers
# defined in docker-compose.test.yml. Committed on purpose — these are
# throwaway credentials for ephemeral containers, and the suite must run with
# zero manual setup.

NODE_ENV=test
PORT=3001
LOG_LEVEL=warn

DATABASE_URL=postgresql://cortist_test:cortist_test@localhost:55432/cortist_test?schema=public

REDIS_HOST=localhost
REDIS_PORT=56379
REDIS_PASSWORD=
REDIS_DB=0

TELEGRAM_BOT_TOKEN=test-bot-token
TELEGRAM_WEBHOOK_SECRET=test-webhook-secret

DEDUPE_TTL_SECONDS=60
WORKER_CONCURRENCY=2

# --- Phase 2 -------------------------------------------------------------
# Throwaway values for ephemeral test containers. The suite never reaches
# Google or Anthropic: the CalendarClient, CalendarIntentClassifier, and
# GoogleOAuthClient providers are all overridden with fakes, so these
# credentials are never used to authenticate anything.
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
GOOGLE_CLIENT_ID=test-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=test-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
OAUTH_STATE_SECRET=test-oauth-state-secret-value
OAUTH_STATE_TTL_SECONDS=900
PUBLIC_BASE_URL=http://localhost:3001
ANTHROPIC_API_KEY=test-anthropic-key
ANTHROPIC_MODEL=claude-haiku-4-5
PENDING_ACTION_TTL_SECONDS=300

# Phase 3. Embeddings are faked in tests, so no model is loaded.
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.3

# The suite binds fakes at RouteClassifier/RagLlm, so no provider is ever
# called. A key is still set so config reports "configured" and the degraded
# path is exercised only where a test asks for it.
LLM_PROVIDER=gemini
GEMINI_API_KEY=test-gemini-key

# Pinned explicitly, not inherited. Nest loads .env as well as this file, and
# anything unset here silently falls through to the developer's own .env — so a
# local DEFAULT_TIMEZONE was enough to fail a test that asserts the UTC
# fallback. Test outcomes must not depend on whose machine they run on.
DEFAULT_TIMEZONE=UTC
CLARIFICATION_TTL_SECONDS=180
WORKER_SHUTDOWN_TIMEOUT_MS=10000

# Explicitly blank, NOT merely absent. Nest loads .env alongside this file, so
# anything unset here inherits the developer's own value — which is exactly how
# a local TIMEZONE_OVERRIDE broke the per-user timezone tests.
TIMEZONE_OVERRIDE=
