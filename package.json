{
  "name": "cortist",
  "version": "0.1.0",
  "description": "Cortist — Telegram ingestion gateway and message queue (Phase 1)",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:gateway": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "dev:gateway": "nest start --watch --entryFile main",
    "dev:worker": "nest start --watch --entryFile worker",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:e2e": "./scripts/test-stack.sh all",
    "test:integration": "./scripts/test-stack.sh integration",
    "test:e2e:only": "./scripts/test-stack.sh e2e",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "format:check": "prettier --check \"{src,test}/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.34.6",
    "googleapis": "^173.0.0",
    "ioredis": "^5.4.2",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
